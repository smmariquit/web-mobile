# GitHub token — private repo counts and stack detection (classic PAT, repo scope)
# GITHUB_TOKEN=

# Vercel Web Analytics dashboard (server-only; same token as CI deploy)
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=team_xxxxxxxx  # Team → Settings, or `vercel teams ls`

# Contact form → Cloudflare Worker (workers/contact/)
# Vercel: add the same values under Project → Settings → Environment Variables
# CONTACT_WORKER_URL=https://contact.stimmie.dev
# CONTACT_SECRET=generate-a-long-random-string

# Optional Turnstile (Cloudflare dashboard → Turnstile)
# NUXT_PUBLIC_TURNSTILE_SITE_KEY=
# Set TURNSTILE_SECRET_KEY on the Worker via: wrangler secret put TURNSTILE_SECRET_KEY

# Worker-side (wrangler secret put CONTACT_SECRET — must match CONTACT_SECRET above)
# Mailchannels DNS on stimmie.dev zone: TXT _mailchannels  v=mc1;
